# ============================================
# Fjellferdigheter — Miljøvariabler
# Kopier til .env og fyll inn verdier
# ============================================

# --- DataForSEO ---
# Registrer konto: https://dataforseo.com/
# API credentials finnes under Dashboard > API Access
DATAFORSEO_LOGIN=din-epost@example.com
DATAFORSEO_PASSWORD=ditt-api-passord

# --- Google Trends ---
# Ingen API-nøkkel nødvendig — bruker uoffisiell API via pytrends
# (Ingen variabler trengs)

# --- Playwright / Web Scraping ---
# Valgfri proxy for scraping ved blokkering
# Format: http://bruker:passord@proxy-host:port
SCRAPER_PROXY_URL=

# --- Plagiatsjekk (Copyscape) ---
# Registrer konto: https://www.copyscape.com/apiconfigure.php
COPYSCAPE_USERNAME=ditt-brukernavn
COPYSCAPE_API_KEY=din-api-nøkkel

# --- Lighthouse / PageSpeed Insights ---
# Opprett nøkkel: https://console.cloud.google.com/apis/credentials
# Aktiver "PageSpeed Insights API" i Google Cloud Console
GOOGLE_PAGESPEED_API_KEY=din-api-nøkkel

# --- Google Rich Results ---
# Bruker samme Google Cloud API-nøkkel som PageSpeed
# (Ingen ekstra variabel trengs)

# --- Fjellvarden OS / SOP ---
# Intern API for oppgavestyring
FJELLVARDEN_OS_API_URL=https://os.fjellvarden.no/api
FJELLVARDEN_OS_API_KEY=din-api-nøkkel

# --- E-post (Resend) ---
# Registrer konto: https://resend.com/
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Netlify ---
# Opprett personal access token: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=din-token
NETLIFY_SITE_ID=site-id-for-preview-deploys
